{
  "entity": "mobile_plan",
  "description": "Mobile network tariff",
  "attributes": [
    {
      "name": "plan_id",
      "type": "string"
    },
    {
      "name": "provider",
      "type": "string"
    },
    {
      "name": "plan_name",
      "type": "string"
    },
    {
      "name": "monthly_price_eur",
      "type": "float"
    },
    {
      "name": "data_gb",
      "type": "float",
      "description": "Monthly mobile data allowance"
    },
    {
      "name": "data_unlimited",
      "type": "boolean"
    },
    {
      "name": "contract_months",
      "type": "integer"
    },
    {
      "name": "network_type",
      "type": "string",
      "enum": ["4G", "5G"]
    },
    {
      "name": "sms_included",
      "type": "boolean"
    },
    {
      "name": "calls_included",
      "type": "boolean"
    },
    {
      "name": "roaming_eu",
      "type": "boolean"
    }
  ]
}