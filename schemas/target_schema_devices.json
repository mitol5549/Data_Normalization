      "type": "integer"
    },
    {
      "name": "ram_gb",
      "type": "integer"
    },
    {
      "name": "screen_size_inch",
      "type": "float"
    },
    {
      "name": "battery_mah",
      "type": "integer"
    },
    {
      "name": "os",
      "type": "string"
    },
    {
